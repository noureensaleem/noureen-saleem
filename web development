```html
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Two Rows with Equal Columns</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      grid-template-rows: 1fr 1fr;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      height: 100%;
    }

    .frame {
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 1.2rem;
      font-family: Arial, sans-serif;
    }

    .frame1 { background: #ff6b6b; }
    .frame2 { background: #4dabf7; }
    .frame3 { background: #51cf66; }
    .frame4 { background: #fcc419; }
  </style>
</head>
<body>
  <div class="row">
    <div class="frame frame1">Frame 1</div>
    <div class="frame frame2">Frame 2</div>
  </div>
  <div class="row">
    <div class="frame frame3">Frame 3</div>
    <div class="frame frame4">Frame 4</div>
  </div>
</body>
</html>
