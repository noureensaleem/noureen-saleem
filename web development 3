<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <title>College Event</title>
    <style>
        body {font-family: Arial, sans-serif; margin: 0; padding: 0;}
        header {background: #4CAF50; color: white; padding: 10px 0; text-align: center;}
        nav {margin: 20px;}
        nav a {margin: 10px; text-decoration: none; color: #333;}
        .event-details {margin: 20px;}
        .event-details img {max-width: 100%; height: auto;}
        table {width: 100%; border-collapse: collapse; margin: 20px 0;}
        th, td {border: 1px solid #ddd; padding: 8px;}
        th {background-color: #4CAF50; color: white;}
        @media (max-width: 600px) {
            table, thead, tbody, th, td, tr {display: block;}
            th {display: none;}
            td {text-align: left;}
        }
    </style>
</head>
<body>
    <header>
        <h1>Welcome to Our College Event!</h1>
    </header>
    <nav>
        <a href="#about">About</a>
        <a href="#events">Events</a>
        <a href="#schedule">Schedule</a>
        <a href="#contact">Contact</a>
    </nav>
    <div class="event-details">
        <section id="about">
            <h2>About the Event</h2>
            <p>This event is designed to bring students together for a fun day of activities and networking.</p>
            <img src="event-image.jpg" alt="College Event">
        </section>
        <section id="events">
            <h2>Event Details</h2>
            <p>Join us on April 30, 2026, for a day filled with exciting activities!</p>
            <ul>
                <li>Workshops</li>
                <li>Guest Speakers</li>
                <li>Networking Opportunities</li>
            </ul>
        </section>
        <section id="schedule">
            <h2>Event Schedule</h2>
            <table>
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Activity</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>10:00 AM</td>
                        <td>Opening Ceremony</td>
                    </tr>
                    <tr>
                        <td>11:00 AM</td>
                        <td>Workshop 1</td>
                    </tr>
                    <tr>
                        <td>1:00 PM</td>
                        <td>Lunch</td>
                    </tr>
                    <tr>
                        <td>2:00 PM</td>
                        <td>Workshop 2</td>
                    </tr>
                    <tr>
                        <td>4:00 PM</td>
                        <td>Networking Session</td>
                    </tr>
                </tbody>
            </table>
        </section>
        <footer>
            <h2 id="contact">Contact Us</h2>
            <p>Email us at: <a href="mailto:event@example.com">event@example.com</a></p>
        </footer>
    </div>
</body>
</html>
